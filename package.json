{
  "name": "ai-arcade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:seed:if-empty": "tsx src/lib/db/seed.ts --if-empty",
    "db:studio": "drizzle-kit studio",
    "release": "drizzle-kit push --force && npm run db:seed:if-empty",
    "start:railway": "npm run release && next start -p ${PORT:-3000}"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.119",
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/openai": "^3.0.73",
    "ai": "^6.0.208",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
