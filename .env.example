# AI Provider
# Options: anthropic (default) | openai | bedrock
AI_PROVIDER=anthropic

# Override the default model for the selected provider
# Defaults: claude-sonnet-4-6 (anthropic) | gpt-4o (openai) | Bedrock Claude inference profile (bedrock)
# AI_MODEL=

# Anthropic — required when AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# OpenAI — required when AI_PROVIDER=openai
# OPENAI_API_KEY=

# Amazon Bedrock — required when AI_PROVIDER=bedrock
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BEDROCK_API_KEY=

# Database
# Default: ./data/arcade.db
# DATABASE_PATH=./data/arcade.db
